# Visual Studio cache/options (исключаем, не нужно для компиляции)
.vs/

# Промежуточные файлы компиляции (obj, pch, ipch)
**/obj/
**/*.obj
**/*.pch
**/*.ipch
**/*.iobj
**/*.ipdb
ipch/
*.pch
*.iobj
*.ipdb

# Отладочные символы (PDB) - большие файлы, не нужны для работы
*.pdb
*.idb
*.iobj
*.ipdb

# Файлы прекомпилированных заголовков
*_i.c
*_p.c
*_h.h

# Результаты сборки Debug
**/[Dd]ebug/**/obj/
**/[Dd]ebug/**/*.pdb
**/[Dd]ebug/**/*.ilk
**/[Dd]ebug/**/*.idb

# НЕ ИСКЛЮЧАЕМ Release/x64 - там скомпилированный .exe
# **/[Rr]elease/**/  <-- закомментировано намеренно

# Проектные файлы VS (не исключаем - нужны для компиляции)
*.sln
*.sln.docstates
*.vcxproj
*.vcxproj.filters
*.vcxproj.user

# Qt/MOC файлы (генерируются при сборке, не нужны в репозитории)
**/moc_*.cpp
**/qrc_*.cpp
**/ui_*.h

# Лог-файл приложения (создаётся при работе)
monitor.log

# Конфигурация приложения (создаётся при работе)
apps.json

# Пользовательские файлы Visual Studio
*.suo
*.user
*.userosscache

# Текстовые файлы сбоя/трассировки
*.log
*.tlog

# Кэш Visual Studio
*.aps
*.ncb
*.opendb
*.opensdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# Профилировщик
*.psess
*.vsp
*.vspx

# Windows
Thumbs.db
Desktop.ini
~$*